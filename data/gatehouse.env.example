# /etc/gatehouse/gatehouse.env — Kopie von gatehouse.env.example
# Vor dem Start ausfüllen und als /etc/gatehouse/gatehouse.env ablegen.
# Berechtigungen: chmod 640 /etc/gatehouse/gatehouse.env

# Pflichtfeld: 64 Hex-Zeichen (= 32-Byte AES-256-GCM-Schlüssel für Ticket-Vault)
GATEHOUSE_MASTER_KEY_HEX=CHANGE_ME_use_openssl_rand_-hex_32

# Kerberos-Realm (für Login und Einladungsflow)
#GATEHOUSE_REALM=EXAMPLE.COM

# Kerberos-Admin (für Einladungsabschluss — leer lassen, um Einladungen zu deaktivieren)
#GATEHOUSE_KADM5_ADMIN_PRINC=admin/admin@EXAMPLE.COM
#GATEHOUSE_KADM5_ADMIN_PASS=

# E-Mail-Versand für OTP-Einladungen
# backend=console: gibt Mails auf stdout aus (für Tests)
# backend=curl:    sendet über SMTP
#GATEHOUSE_EMAIL_BACKEND=console
#GATEHOUSE_SMTP_USER=
#GATEHOUSE_SMTP_PASS=
#GATEHOUSE_SMTP_URL=smtps://mail.example.com:465
